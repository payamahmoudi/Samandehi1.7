# ━━━━━━━━ نمونهٔ فایل تنظیمات سامانه ━━━━━━━━
# این فایل را با نام «.env» کپی کنید و مقادیر را پر کنید:
#     cp .env.example .env
# سپس مقادیر SECRET_KEY و ADMIN_PASSWORD را حتماً تغییر دهید.

# محیط اجرا (در سرور حتماً production بماند)
APP_ENV=production

# کلید رمزنگاری توکن‌ها — یک کلید تصادفی قوی بسازید:
#     python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY= @Mr.pkil3r

# مدیر اصلی سامانه (رمز اولیه؛ بعد از اولین ورود از داخل سامانه تغییر دهید)
ADMIN_USERNAME=paya
ADMIN_PASSWORD=Mahmoudi80
ADMIN_FULLNAME=پایا محمودی

# آدرس(های) مجاز فرانت‌اند برای CORS.
# در روش Docker (پروکسی same-origin) نیازی نیست؛ خالی بگذارید.
# اگر بک‌اند را جدا منتشر می‌کنید، آدرس دامنهٔ فرانت را بگذارید:
#   FRONTEND_ORIGINS=https://saman.example.com
FRONTEND_ORIGINS=

# مدت اعتبار توکن ورود (دقیقه) — پیش‌فرض ۸ ساعت
ACCESS_TOKEN_EXPIRE_MINUTES=480

# محدودیت تلاش ورود (ضد Brute-force)
LOGIN_MAX_ATTEMPTS=8
LOGIN_WINDOW_SECONDS=300

# حداقل طول رمز عبور کاربران
PASSWORD_MIN_LENGTH=8

# پورت وبی که سامانه روی آن سرو می‌شود (پیش‌فرض ۸۰)
WEB_PORT=80

# راز رمزنگاری فایل‌های پشتیبان (AES). برای هر استقرار یک مقدار یکتا بسازید:
#     python3 -c "import secrets; print(secrets.token_urlsafe(32))"
VITE_BACKUP_SECRET=
